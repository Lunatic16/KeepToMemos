# KeepToMemos Configuration
# Copy this file to .env and fill in your values

# Memos API base URL (required)
# Must end with a trailing slash
MEMOS_BASE_URL=http://localhost:5230/api/v1/

# Memos Personal Access Token (required)
# Generate in Memos: Settings → My Account → Access Tokens
MEMOS_ACCESS_TOKEN=memos_pat_your_token_here

# Google Keep Takeout directory (optional, default: ./)
KEEP_TAKEOUT_DIR=./Takeout/Keep/
